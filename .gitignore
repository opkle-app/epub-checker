.vscode/
.idea/
.fleet/
.claude/
.codex/

# Local environment and package-manager credentials
.env
.env.*
!.env.example
.npmrc

# Signing keys and certificates
*.key
*.pem
*.p12
*.pfx

# GitHub token / notarization credentials some CLIs write to disk locally
