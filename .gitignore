electron-builder.env
notarize.json

# Dependencies
node_modules/

# Logs and caches
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.cache/
.rspack-cache/
*.tsbuildinfo

# Generated build, test, and release output
dist/
out/
release/
coverage/
temp/

# electron-builder artifacts, in case they ever land outside release/
*.blockmap
latest*.yml
builder-effective-config.yaml

# Renderer output generated by renderer:build / renderer:watch
renderer/index.html
renderer/main.mjs
renderer/main.mjs.map
source/apps/abstractNode/src/rspack.config.mjs

# Portable JRE, EPUBCheck, and Chromium runtimes
launcher/*
!launcher/README.md

# User EPUB files may contain private or copyrighted content.
# Explicitly allow only curated public test fixtures.
*.epub
!test/fixtures/**/*.epub
