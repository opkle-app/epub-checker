{
  "name": "epub-checker",
  "version": "0.1.3-beta.1",
  "description": "Opkle이 만든 무료 로컬 EPUB 검사·편집 도구",
  "main": "dist/main.js",
  "type": "module",
  "productName": "EpubChecker",
  "homepage": "https://opkle.app",
  "scripts": {
    "tsc": "tsc",
    "tsc:preload": "tsc --project preconfig.json",
    "renderer:build": "tsx source/apps/abstractNode/abstractNode.ts build",
    "renderer:watch": "tsx source/apps/abstractNode/abstractNode.ts watch",
    "build:all": "npm run renderer:build && npm run tsc && npm run tsc:preload",
    "start": "electron .",
    "dev": "npm run build:all && cross-env NODE_ENV=development electron .",
    "check": "npm run build:all",
    "test:backend": "tsx test/backend-smoke.ts",
    "test:renderer-store": "tsx test/workspace-store-smoke.ts",
    "verify": "npm run format:check && npm run check && npm run test:backend && npm run test:renderer-store",
    "launcher:setup": "node scripts/setup-launcher.mjs",
    "launcher:setup:rebuild": "cross-env FORCE=1 node scripts/setup-launcher.mjs",
    "launcher:setup:mac:x64": "cross-env LAUNCHER_PLATFORM=darwin-x64 node scripts/setup-launcher.mjs",
    "launcher:setup:mac:arm64": "cross-env LAUNCHER_PLATFORM=darwin-arm64 node scripts/setup-launcher.mjs",
    "launcher:setup:win:x64": "cross-env LAUNCHER_PLATFORM=win32-x64 node scripts/setup-launcher.mjs",
    "format": "prettier --write \"source/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.mjs\"",
    "format:check": "prettier --check \"source/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.mjs\"",
    "dist": "npm run build:all && electron-builder",
    "dist:mac": "npm run build:all && electron-builder --mac",
    "dist:win": "npm run build:all && electron-builder --win",
    "dist:win:appx": "npm run build:all && electron-builder --win appx",
    "dist:linux": "npm run build:all && electron-builder --linux"
  },
  "keywords": [
    "epub",
    "epubcheck",
    "accessibility",
    "ace-by-daisy",
    "electron",
    "ebook"
  ],
  "author": {
    "name": "Opkle",
    "url": "https://opkle.app"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.5",
    "@daisy/ace-core": "^1.4.6",
    "@daisy/ace-report": "^1.4.6",
    "@daisy/epub-utils": "^1.4.6",
    "@lezer/highlight": "^1.2.3",
    "@xmldom/xmldom": "^0.9.10",
    "css-tree": "^3.2.1",
    "diff-match-patch": "^1.0.5",
    "electron-log": "^5.4.3",
    "fast-xml-parser": "^5.9.3",
    "fflate": "^0.8.3",
    "file-type": "^22.0.1",
    "htmlparser2": "^12.0.0",
    "jszip": "^3.10.1",
    "playwright": "^1.61.1"
  },
  "devDependencies": {
    "@rspack/cli": "^2.1.2",
    "@rspack/core": "^2.1.2",
    "@types/diff-match-patch": "^1.0.36",
    "@types/node": "^22.14.1",
    "cross-env": "^7.0.3",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "prettier": "^3.5.3",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  },
  "build": {
    "appId": "app.opkle.epubchecker",
    "productName": "EpubChecker",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": ["dist/**/*", "renderer/**/*", "package.json"],
    "asar": true,
    "publish": {
      "provider": "github",
      "owner": "opkle-app",
      "repo": "epub-checker"
    },
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ],
      "extraResources": [
        { "from": "launcher/darwin-${arch}", "to": "launcher/darwin-${arch}", "filter": ["**/*", "!chromium/**"] }
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": ["nsis"],
      "extraResources": [
        { "from": "launcher/win32-${arch}", "to": "launcher/win32-${arch}", "filter": ["**/*"] }
      ]
    },
    "appx": {
      "applicationId": "EpubChecker",
      "backgroundColor": "#0B0B0C",
      "displayName": "EpubChecker",
      "identityName": "REPLACE_WITH_PARTNER_CENTER_IDENTITY_NAME",
      "publisher": "REPLACE_WITH_PARTNER_CENTER_PUBLISHER_CN",
      "publisherDisplayName": "Opkle"
    },
    "linux": {
      "icon": "build/icon.png",
      "target": ["AppImage"],
      "extraResources": [
        { "from": "launcher/linux-${arch}", "to": "launcher/linux-${arch}", "filter": ["**/*"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
