# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.
# electron-builder loads .env automatically at build/publish time.

# ── GitHub Releases publish ──────────────────────────────────────────
# Personal access token with `repo` scope (or a fine-grained token with
# Contents: Read and write) on opkle-app/epub-checker.
# Required for: npm run dist -- --publish=always
GH_TOKEN=

# ── macOS code signing ───────────────────────────────────────────────
# Path to a .p12 "Developer ID Application" certificate, or a base64-encoded
# string of that file. Leave both empty to build an unsigned mac app.
CSC_LINK=
CSC_KEY_PASSWORD=

# ── macOS notarization ────────────────────────────────────────────────
# All three are required together for electron-builder to notarize
# automatically after signing. Required for distributing outside the
# Mac App Store without a Gatekeeper warning.
APPLE_ID=
APPLE_APP_SPECIFIC_PASSWORD=
APPLE_TEAM_ID=

# ── Windows code signing (optional, separate cert from mac) ──────────
WIN_CSC_LINK=
WIN_CSC_KEY_PASSWORD=

# ── launcher:setup options (optional flags, not secrets) ─────────────
# SKIP_JRE=1
# SKIP_CHROMIUM=1
# JRE_VERSION=21
