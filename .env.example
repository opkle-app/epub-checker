# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.
# electron-builder loads .env automatically at build/publish time.

# ── GitHub Releases publish ──────────────────────────────────────────
# Personal access token with `repo` scope (or a fine-grained token with
# Contents: Read and write) on opkle-app/epub-checker.
# Required for: npm run dist -- --publish=always
GH_TOKEN=

# ── macOS code signing ───────────────────────────────────────────────
# Path to a .p12 "Developer ID Application" certificate, or a base64-encoded
# string of that file. Leave both empty to build an unsigned mac app.
CSC_LINK=
CSC_KEY_PASSWORD=

# Identity name matching the same cert as CSC_LINK, e.g.
# "Developer ID Application: Opkle (TEAMID)". electron-builder itself only
# needs CSC_LINK/CSC_KEY_PASSWORD, but scripts/afterPackSignChromium.mjs runs
# BEFORE electron-builder imports that cert, so it needs this identity already
# present in an unlocked keychain (login keychain locally, or a keychain your
# CI workflow imports and unlocks before the build step) to re-sign the
# bundled Chromium runtime (launcher/*/chromium ships adhoc-signed only —
# verified with `codesign -dv --verbose=4`). The bundled JRE is already
# validly signed by Eclipse Foundation and does not need this.
CSC_NAME=

# ── macOS notarization ────────────────────────────────────────────────
# All three are required together for electron-builder to notarize
# automatically after signing. Required for distributing outside the
# Mac App Store without a Gatekeeper warning.
APPLE_ID=
APPLE_APP_SPECIFIC_PASSWORD=
APPLE_TEAM_ID=

# ── Windows code signing (optional, separate cert from mac) ──────────
WIN_CSC_LINK=
WIN_CSC_KEY_PASSWORD=

# ── launcher:setup options (optional flags, not secrets) ─────────────
# SKIP_JRE=1
# SKIP_CHROMIUM=1
# JRE_VERSION=21
