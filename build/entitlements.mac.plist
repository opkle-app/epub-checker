<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!-- Electron/V8 and the bundled JRE both JIT-compile; hardened runtime blocks this by default. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>

    <!-- The bundled JRE under launcher/ is signed by Eclipse Foundation, not Opkle's
         Developer ID, so library validation must stay off or the hardened main
         process refuses to load/spawn it. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Chromium isn't bundled on mac (Apple notarization rejects Playwright's Chrome
         for Testing bundle layout — see source/apps/launcherRuntime.ts); it's downloaded
         into userData on first run instead, so the app needs outbound network access
         for that alone, on top of Electron's own update-check traffic. -->
    <key>com.apple.security.network.client</key>
    <true/>
  </dict>
</plist>
